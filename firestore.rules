rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Admin-managed collections
    match /products/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /blogs/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Orders created from website checkout flow.
    match /orders/{docId} {
      allow create: if true;
      allow read, update, delete: if isSignedIn();
    }

    // Enquiries created from website redirects.
    // Public can create, only authenticated admin can read/update/delete.
    match /enquiries/{docId} {
      allow create: if true;
      allow read, update, delete: if isSignedIn();
    }
  }
}
